<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}{{ "app_name" | trans(locale) }}{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/default.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-brand">{{ "app_name" | trans(locale) }}</a>
        <div class="nav-menu">
            <a href="/" class="nav-link {% if active_page == 'catalog' %}active{% endif %}">{{ "catalog" | trans(locale) }}</a>
            
            {% if session_staff %}
                <a href="/admin" class="nav-link {% if active_page == 'admin' %}active{% endif %}">{{ "admin_panel" | trans(locale) }}</a>
                <span class="nav-link" style="color: #6366f1; cursor: default;">{{ session_staff.name }}</span>
                <a href="/api/auth/logout" class="btn btn-secondary btn-sm" style="margin-left: 0.5rem;">{{ "sign_out" | trans(locale) }}</a>
            {% else %}
                <a href="/login" class="btn btn-primary btn-sm">{{ "login" | trans(locale) }}</a>
            {% endif %}

            <div class="lang-switcher">
                <a href="/language/en" class="{% if locale == 'en' %}active{% endif %}">EN</a>
                <a href="/language/es" class="{% if locale == 'es' %}active{% endif %}">ES</a>
            </div>
        </div>
    </nav>

    <main class="container">
        {% block content %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
</body>
</html>
