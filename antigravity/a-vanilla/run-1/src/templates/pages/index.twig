{% extends "base.twig" %}

{% block content %}
<div class="page-header">
    <h1>{{ "catalog" | trans(locale) }}</h1>
    <p>Browse and search our collection of books</p>
</div>

<form action="/" method="GET" class="search-bar">
    <div class="search-input-wrapper">
        <input type="text" name="q" placeholder="{{ 'search_placeholder' | trans(locale) }}" value="{{ query_q }}" required>
    </div>
    <button type="submit">{{ "catalog" | trans(locale) }}</button>
    {% if query_q %}
        <a href="/" class="btn btn-secondary" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.5rem; text-decoration: none; border-radius: 0.5rem; font-weight: 600;">Clear</a>
    {% endif %}
</form>

{% if books %}
    <div class="card-grid">
        {% for book in books %}
            <div class="card">
                {% if book.cover_image %}
                    <div class="card-cover" style="background-image: url('{{ book.cover_image }}');">
                        {% if book.is_available %}
                            <span class="availability-badge available">{{ "available" | trans(locale) }}</span>
                        {% else %}
                            <span class="availability-badge borrowed">{{ "borrowed" | trans(locale) }}</span>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="card-cover" style="background: linear-gradient(135deg, #1e1b4b, #311042); display: flex; align-items: center; justify-content: center; text-align: center; padding: 1.5rem; box-sizing: border-box;">
                        {% if book.is_available %}
                            <span class="availability-badge available">{{ "available" | trans(locale) }}</span>
                        {% else %}
                            <span class="availability-badge borrowed">{{ "borrowed" | trans(locale) }}</span>
                        {% endif %}
                        <div style="font-weight: 800; font-size: 1.5rem; color: rgba(255,255,255,0.8);">{{ book.title }}</div>
                    </div>
                {% endif %}
                <div class="card-content">
                    <h3 class="card-title" title="{{ book.title }}">{{ book.title }}</h3>
                    <p class="card-author">{{ book.author }}</p>
                    <div class="card-footer">
                        <span class="card-year">{{ book.published_year }}</span>
                        <a href="/book/{{ book.id }}" class="btn-details">{{ "details" | trans(locale) }}</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {% if total_pages > 1 %}
        <div class="pagination">
            <a href="/?q={{ query_q }}&page={{ current_page - 1 }}" class="btn-page {% if current_page <= 1 %}disabled{% endif %}">&larr; Previous</a>
            <span class="page-info">Page {{ current_page }} of {{ total_pages }}</span>
            <a href="/?q={{ query_q }}&page={{ current_page + 1 }}" class="btn-page {% if current_page >= total_pages %}disabled{% endif %}">Next &rarr;</a>
        </div>
    {% endif %}
{% else %}
    <div class="alert alert-danger" style="text-align: center; margin-top: 4rem;">
        No books found matching your criteria.
    </div>
{% endif %}
{% endblock %}
