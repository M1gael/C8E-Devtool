{% extends "base.twig" %}

{% block content %}
<div class="page-header" style="text-align: left; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1>{{ "admin_panel" | trans(locale) }}</h1>
        <p>Library management dashboard</p>
    </div>
</div>

<div class="admin-nav">
    <button class="tab-btn active" onclick="switchTab('books-tab')">{{ "books" | trans(locale) }}</button>
    <button class="tab-btn" onclick="switchTab('members-tab')">{{ "members" | trans(locale) }}</button>
    <button class="tab-btn" onclick="switchTab('loans-tab')">{{ "loans" | trans(locale) }}</button>
    <button class="tab-btn" onclick="switchTab('logs-tab')">{{ "audit_logs" | trans(locale) }}</button>
</div>

<!-- SUCCESS/ERROR NOTIFICATIONS -->
<div id="alertContainer"></div>

<!-- ==================== BOOKS TAB ==================== -->
<div id="books-tab" class="tab-panel active">
    <div class="action-bar">
        <h2>{{ "books" | trans(locale) }}</h2>
        <button class="btn btn-primary btn-sm" onclick="openModal('addBookModal')">+ {{ "add_book" | trans(locale) }}</button>
    </div>
    
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>{{ "book_title" | trans(locale) }}</th>
                    <th>{{ "author" | trans(locale) }}</th>
                    <th>{{ "published_year" | trans(locale) }}</th>
                    <th>{{ "isbn" | trans(locale) }}</th>
                    <th>{{ "availability" | trans(locale) }}</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for book in books %}
                    <tr>
                        <td>{{ book.id }}</td>
                        <td><strong>{{ book.title }}</strong></td>
                        <td>{{ book.author }}</td>
                        <td>{{ book.published_year }}</td>
                        <td>{{ book.isbn }}</td>
                        <td>
                            {% if book.is_available %}
                                <span style="color: #10b981; font-weight: 600;">{{ "available" | trans(locale) }}</span>
                            {% else %}
                                <span style="color: #ef4444; font-weight: 600;">{{ "borrowed" | trans(locale) }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <button class="btn btn-secondary btn-sm" onclick="populateEditBook({{ book | json_encode | safe }})">Edit</button>
                            <button class="btn btn-danger btn-sm" onclick="deleteBook({{ book.id }})">Delete</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== MEMBERS TAB ==================== -->
<div id="members-tab" class="tab-panel">
    <div class="action-bar">
        <h2>{{ "members" | trans(locale) }}</h2>
        <button class="btn btn-primary btn-sm" onclick="openModal('addMemberModal')">+ {{ "add_member" | trans(locale) }}</button>
    </div>
    
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Join Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for member in members %}
                    <tr>
                        <td>{{ member.id }}</td>
                        <td><strong>{{ member.name }}</strong></td>
                        <td>{{ member.email }}</td>
                        <td>{{ member.join_date }}</td>
                        <td>
                            <button class="btn btn-secondary btn-sm" onclick="populateEditMember({{ member | json_encode | safe }})">Edit</button>
                            <button class="btn btn-danger btn-sm" onclick="deleteMember({{ member.id }})">Delete</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== LOANS TAB ==================== -->
<div id="loans-tab" class="tab-panel">
    <div class="action-bar">
        <h2>{{ "loans" | trans(locale) }}</h2>
        <button class="btn btn-primary btn-sm" onclick="openModal('recordLoanModal')">+ {{ "record_loan" | trans(locale) }}</button>
    </div>
    
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Book</th>
                    <th>Member</th>
                    <th>{{ "borrow_date" | trans(locale) }}</th>
                    <th>{{ "due_date" | trans(locale) }}</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for loan in loans %}
                    <tr>
                        <td>{{ loan.id }}</td>
                        <td><strong>{{ loan.book_title }}</strong></td>
                        <td>{{ loan.member_name }}</td>
                        <td>{{ loan.borrow_date }}</td>
                        <td>{{ loan.due_date }}</td>
                        <td>
                            {% if loan.returned %}
                                <span style="color: #10b981; font-weight: 600;">Returned ({{ loan.returned_date }})</span>
                            {% else %}
                                <span style="color: #ef4444; font-weight: 600;">Active</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if not loan.returned %}
                                <button class="btn btn-success btn-sm" onclick="returnLoan({{ loan.id }})">{{ "record_return" | trans(locale) }}</button>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== LOGS TAB ==================== -->
<div id="logs-tab" class="tab-panel">
    <div class="action-bar">
        <h2>{{ "audit_logs" | trans(locale) }}</h2>
    </div>
    
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Staff Member</th>
                    <th>Action</th>
                    <th>Target</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for log in audit_logs %}
                    <tr>
                        <td>{{ log.created_at }}</td>
                        <td><strong>{{ log.staff_name }}</strong> (ID: {{ log.staff_id }})</td>
                        <td><span style="color: #a855f7; font-weight: 600;">{{ log.action }}</span></td>
                        <td>{{ log.target_type }} #{{ log.target_id }}</td>
                        <td>{{ log.details }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== MODALS ==================== -->

<!-- ADD BOOK MODAL -->
<div id="addBookModal" class="modal-overlay">
    <div class="modal-card">
        <h2>{{ "add_book" | trans(locale) }}</h2>
        <form onsubmit="submitForm(event, '/api/books', 'POST')">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" placeholder="Enter book title..." required>
            </div>
            <div class="form-group">
                <label>Author</label>
                <input type="text" name="author" placeholder="Enter author name..." required>
            </div>
            <div class="form-group">
                <label>Published Year</label>
                <input type="number" name="published_year" placeholder="e.g. 2026" required min="1000" max="2100">
            </div>
            <div class="form-group">
                <label>ISBN</label>
                <input type="text" name="isbn" placeholder="e.g. 978-3-16-148410-0" required>
            </div>
            <div class="form-group">
                <label>Cover Image URL (optional)</label>
                <input type="url" name="cover_image" placeholder="https://example.com/cover.jpg">
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addBookModal')">{{ "cancel" | trans(locale) }}</button>
                <button type="submit" class="btn btn-primary">{{ "submit" | trans(locale) }}</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT BOOK MODAL -->
<div id="editBookModal" class="modal-overlay">
    <div class="modal-card">
        <h2>{{ "edit_book" | trans(locale) }}</h2>
        <form id="editBookForm" onsubmit="submitEditBook(event)">
            <input type="hidden" name="id">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" required>
            </div>
            <div class="form-group">
                <label>Author</label>
                <input type="text" name="author" required>
            </div>
            <div class="form-group">
                <label>Published Year</label>
                <input type="number" name="published_year" required min="1000" max="2100">
            </div>
            <div class="form-group">
                <label>ISBN</label>
                <input type="text" name="isbn" required>
            </div>
            <div class="form-group">
                <label>Cover Image URL (optional)</label>
                <input type="url" name="cover_image">
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editBookModal')">{{ "cancel" | trans(locale) }}</button>
                <button type="submit" class="btn btn-primary">{{ "submit" | trans(locale) }}</button>
            </div>
        </form>
    </div>
</div>

<!-- ADD MEMBER MODAL -->
<div id="addMemberModal" class="modal-overlay">
    <div class="modal-card">
        <h2>{{ "add_member" | trans(locale) }}</h2>
        <form onsubmit="submitForm(event, '/api/members', 'POST')">
            <div class="form-group">
                <label>Name</label>
                <input type="text" name="name" placeholder="Enter member name..." required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="member@example.com" required>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addMemberModal')">{{ "cancel" | trans(locale) }}</button>
                <button type="submit" class="btn btn-primary">{{ "submit" | trans(locale) }}</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT MEMBER MODAL -->
<div id="editMemberModal" class="modal-overlay">
    <div class="modal-card">
        <h2>{{ "edit_member" | trans(locale) }}</h2>
        <form id="editMemberForm" onsubmit="submitEditMember(event)">
            <input type="hidden" name="id">
            <div class="form-group">
                <label>Name</label>
                <input type="text" name="name" required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editMemberModal')">{{ "cancel" | trans(locale) }}</button>
                <button type="submit" class="btn btn-primary">{{ "submit" | trans(locale) }}</button>
            </div>
        </form>
    </div>
</div>

<!-- RECORD LOAN MODAL -->
<div id="recordLoanModal" class="modal-overlay">
    <div class="modal-card">
        <h2>{{ "record_loan" | trans(locale) }}</h2>
        <form onsubmit="submitForm(event, '/api/loans', 'POST')">
            <div class="form-group">
                <label>{{ "select_book" | trans(locale) }}</label>
                <select name="book_id" required>
                    <option value="">-- Choose Book --</option>
                    {% for book in books %}
                        {% if book.is_available %}
                            <option value="{{ book.id }}">{{ book.title }} (by {{ book.author }})</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
            <div class="form-group">
                <label>{{ "select_member" | trans(locale) }}</label>
                <select name="member_id" required>
                    <option value="">-- Choose Member --</option>
                    {% for member in members %}
                        <option value="{{ member.id }}">{{ member.name }} ({{ member.email }})</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group">
                <label>Due Date</label>
                <input type="date" name="due_date" id="loan_due_date" required>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('recordLoanModal')">{{ "cancel" | trans(locale) }}</button>
                <button type="submit" class="btn btn-primary">{{ "submit" | trans(locale) }}</button>
            </div>
        </form>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
    // Tab switching
    function switchTab(tabId) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        
        document.getElementById(tabId).classList.add('active');
        event.currentTarget.classList.add('active');
        
        // Save current tab in localStorage
        localStorage.setItem('lend_active_tab', tabId);
    }
    
    // Restore tab on reload
    document.addEventListener("DOMContentLoaded", () => {
        const savedTab = localStorage.getItem('lend_active_tab');
        if (savedTab && document.getElementById(savedTab)) {
            const btn = Array.from(document.querySelectorAll('.tab-btn')).find(b => b.getAttribute('onclick').includes(savedTab));
            if (btn) btn.click();
        }
        
        // Set default due date to 14 days from today
        const dueDateInput = document.getElementById('loan_due_date');
        if (dueDateInput) {
            const today = new Date();
            const future = new Date(today.getTime() + 14 * 24 * 60 * 60 * 1000);
            const yyyy = future.getFullYear();
            let mm = future.getMonth() + 1;
            let dd = future.getDate();
            if (mm < 10) mm = '0' + mm;
            if (dd < 10) dd = '0' + dd;
            dueDateInput.value = `${yyyy}-${mm}-${dd}`;
        }
    });

    // Modal open/close
    function openModal(id) {
        document.getElementById(id).classList.add('active');
    }
    
    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }

    // Alerts helper
    function showAlert(message, type = 'success') {
        const container = document.getElementById('alertContainer');
        container.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Submit forms via API
    async function submitForm(event, url, method) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => data[key] = value);

        try {
            const response = await fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Action completed successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }

    // Edit book
    function populateEditBook(book) {
        const form = document.getElementById('editBookForm');
        form.elements['id'].value = book.id;
        form.elements['title'].value = book.title;
        form.elements['author'].value = book.author;
        form.elements['published_year'].value = book.published_year;
        form.elements['isbn'].value = book.isbn;
        form.elements['cover_image'].value = book.cover_image || '';
        openModal('editBookModal');
    }

    async function submitEditBook(event) {
        event.preventDefault();
        const form = event.target;
        const id = form.elements['id'].value;
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => data[key] = value);

        try {
            const response = await fetch(`/api/books/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Book updated successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }

    // Delete book
    async function deleteBook(id) {
        if (!confirm('Are you sure you want to delete this book?')) return;

        try {
            const response = await fetch(`/api/books/${id}`, {
                method: 'DELETE'
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Book deleted successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }

    // Edit member
    function populateEditMember(member) {
        const form = document.getElementById('editMemberForm');
        form.elements['id'].value = member.id;
        form.elements['name'].value = member.name;
        form.elements['email'].value = member.email;
        openModal('editMemberModal');
    }

    async function submitEditMember(event) {
        event.preventDefault();
        const form = event.target;
        const id = form.elements['id'].value;
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => data[key] = value);

        try {
            const response = await fetch(`/api/members/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Member updated successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }

    // Delete member
    async function deleteMember(id) {
        if (!confirm('Are you sure you want to delete this member?')) return;

        try {
            const response = await fetch(`/api/members/${id}`, {
                method: 'DELETE'
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Member deleted successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }

    // Return loan
    async function returnLoan(id) {
        try {
            const response = await fetch(`/api/loans/${id}/return`, {
                method: 'POST'
            });
            const result = await response.json();

            if (response.ok) {
                showAlert(result.message || 'Book returned successfully!');
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert(result.error || result.message || 'An error occurred.', 'danger');
            }
        } catch (error) {
            showAlert('Network error: ' + error.message, 'danger');
        }
    }
</script>
{% endblock %}
