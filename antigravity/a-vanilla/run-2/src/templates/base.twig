<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}BookStack — Premium Library Manager{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="A premium library manager and book tracker built with Tina4 Python.">
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for beautiful icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/app.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <div class="app-container">
        <!-- Sidebar or Header -->
        <header class="app-header">
            <div class="header-content">
                <div class="logo">
                    <i class="fa-solid fa-book-bookmark logo-icon"></i>
                    <span class="logo-text">Book<span class="highlight">Stack</span></span>
                </div>
                <div class="header-actions">
                    <button class="btn btn-primary" onclick="openAddModal()">
                        <i class="fa-solid fa-plus"></i> Add New Book
                    </button>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="app-main">
            {% block content %}{% endblock %}
        </main>

        <!-- Footer -->
        <footer class="app-footer">
            <p>&copy; 2026 BookStack Library Manager. Built with <a href="https://tina4.com" target="_blank">Tina4 Python</a> &amp; SQLite.</p>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="/js/tina4.min.js" ignore missing></script>
    <script src="/js/frond.min.js" ignore missing></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
