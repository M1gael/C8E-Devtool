<!DOCTYPE html>
<html lang="{{ active_lang | default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ t.t('nav.title') }}{% endblock %}</title>
    <link rel="stylesheet" href="/css/style.css">
    {% block head %}{% endblock %}
</head>
<body>
    <header class="glass shadow-premium">
        <div class="nav-container">
            <a href="/" class="logo">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #6366f1;"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                {{ t.t('nav.title') }}
            </a>
            
            <nav class="nav-menu">
                <a href="/" class="nav-link {% if page == 'catalogue' %}active{% endif %}">{{ t.t('nav.catalogue') }}</a>
                {% if user %}
                    <a href="/dashboard" class="nav-link {% if page == 'dashboard' %}active{% endif %}">{{ t.t('nav.dashboard') }}</a>
                    <a href="/logout" class="btn-secondary" style="font-size: 0.9rem; padding: 6px 14px;">{{ t.t('nav.logout') }}</a>
                {% else %}
                    <a href="/login" class="btn-primary" style="font-size: 0.9rem; padding: 6px 14px;">{{ t.t('nav.login') }}</a>
                {% endif %}
                
                <div class="lang-switcher">
                    <a href="?lang=en" class="lang-btn {% if active_lang == 'en' %}active{% endif %}">EN</a>
                    <a href="?lang=es" class="lang-btn {% if active_lang == 'es' %}active{% endif %}">ES</a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        {% if flash_message %}
            <div class="alert alert-{{ flash_type | default('info') }} shadow-premium">
                {{ flash_message }}
            </div>
        {% endif %}
        
        {% block content %}{% endblock %}
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 {{ t.t('nav.title') }}. All rights reserved.</p>
        </div>
    </footer>
    
    {% block scripts %}{% endblock %}
</body>
</html>
