{% extends "base.twig" %}

{% block title %}Admin Dashboard{% endblock %}

{% block content %}
  <div class="admin-header">
    <div>
      <h1>Library Administration</h1>
      <p style="color: #9ca3af;">Manage catalogue, library members, and track loans/returns.</p>
    </div>
  </div>

  <!-- Admin Navigation Tabs -->
  <div class="admin-tabs">
    <a href="/admin" class="active">Overview</a>
    <a href="/admin/books">Books</a>
    <a href="/admin/members">Members</a>
    <a href="/admin/loans">Loans & Returns</a>
    <a href="/admin/logs">Audit Logs</a>
  </div>

  {% if success %}
    <div class="alert alert-success">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-danger">{{ error }}</div>
  {% endif %}

  <!-- Overview Stats -->
  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 3rem;">
    <div class="card" style="padding: 1.5rem; text-align: center; justify-content: center;">
      <h4 style="color: #9ca3af; font-size: 0.9rem; text-transform: uppercase;">Total Books</h4>
      <p style="font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        {{ stats.books }}
      </p>
    </div>
    <div class="card" style="padding: 1.5rem; text-align: center; justify-content: center;">
      <h4 style="color: #9ca3af; font-size: 0.9rem; text-transform: uppercase;">Total Members</h4>
      <p style="font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        {{ stats.members }}
      </p>
    </div>
    <div class="card" style="padding: 1.5rem; text-align: center; justify-content: center;">
      <h4 style="color: #9ca3af; font-size: 0.9rem; text-transform: uppercase;">Active Loans</h4>
      <p style="font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        {{ stats.active_loans }}
      </p>
    </div>
    <div class="card" style="padding: 1.5rem; text-align: center; justify-content: center;">
      <h4 style="color: #9ca3af; font-size: 0.9rem; text-transform: uppercase;">Returned Loans</h4>
      <p style="font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        {{ stats.returned_loans }}
      </p>
    </div>
  </div>

  <!-- Recent Loans -->
  <div class="history-section">
    <h2>Recent Activity (Active Loans)</h2>
    {% if active_loans|length > 0 %}
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Book</th>
              <th>Member</th>
              <th>Borrow Date</th>
              <th>Due Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for loan in active_loans %}
              <tr>
                <td><strong>{{ loan.book.title }}</strong><br><span style="font-size: 0.8rem; color: #9ca3af;">by {{ loan.book.author }}</span></td>
                <td>{{ loan.member.name }}<br><span style="font-size: 0.8rem; color: #9ca3af;">{{ loan.member.email }}</span></td>
                <td>{{ loan.borrow_date }}</td>
                <td>{{ loan.due_date }}</td>
                <td>
                  <form action="/admin/loans/return" method="POST" style="display:inline;">
                    {{ form_token() }}
                    <input type="hidden" name="loan_id" value="{{ loan.id }}">
                    <button type="submit" class="btn btn-success btn-sm">Record Return</button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <p style="color: #9ca3af; font-style: italic;">No active loans at this time. All books are in the library catalogue!</p>
    {% endif %}
  </div>
{% endblock %}
