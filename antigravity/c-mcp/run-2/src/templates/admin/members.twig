{% extends "base.twig" %}

{% block title %}Manage Members - Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <div>
      <h1>Library Administration</h1>
      <p style="color: #9ca3af;">Manage registered library members.</p>
    </div>
  </div>

  <!-- Admin Navigation Tabs -->
  <div class="admin-tabs">
    <a href="/admin">Overview</a>
    <a href="/admin/books">Books</a>
    <a href="/admin/members" class="active">Members</a>
    <a href="/admin/loans">Loans & Returns</a>
    <a href="/admin/logs">Audit Logs</a>
  </div>

  {% if success %}
    <div class="alert alert-success">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-danger">{{ error }}</div>
  {% endif %}

  <div class="grid" style="grid-template-columns: 350px 1fr; align-items: start;">
    <!-- Add or Edit Member Form -->
    <div class="card" style="padding: 1.5rem;">
      <h3>{% if edit_member %}Edit Member{% else %}Register Member{% endif %}</h3>
      
      <form action="{% if edit_member %}/admin/members/edit/{{ edit_member.id }}{% else %}/admin/members/add{% endif %}" method="POST">
        {{ form_token() }}
        
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required value="{{ edit_member.name }}" placeholder="e.g. Alice Smith">
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required value="{{ edit_member.email }}" placeholder="e.g. alice@example.com">
        </div>

        <div style="display: flex; gap: 0.5rem; margin-top: 1.5rem;">
          <button type="submit" class="btn btn-primary" style="flex-grow: 1;">
            {% if edit_member %}Save Changes{% else %}Register{% endif %}
          </button>
          {% if edit_member %}
            <a href="/admin/members" class="btn btn-secondary">Cancel</a>
          {% endif %}
        </div>
      </form>
    </div>

    <!-- Members List Table -->
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Join Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for member in members %}
            <tr>
              <td><strong>{{ member.name }}</strong></td>
              <td>{{ member.email }}</td>
              <td>{{ member.join_date }}</td>
              <td>
                <div style="display: flex; gap: 0.5rem;">
                  <a href="/admin/members?edit_id={{ member.id }}" class="btn btn-secondary btn-sm">Edit</a>
                  
                  <form action="/admin/members/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this member?');" style="display:inline;">
                    {{ form_token() }}
                    <input type="hidden" name="member_id" value="{{ member.id }}">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="4" style="text-align: center; color: #9ca3af; font-style: italic;">No members registered yet. Add one above!</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
