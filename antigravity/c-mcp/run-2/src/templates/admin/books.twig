{% extends "base.twig" %}

{% block title %}Manage Books - Admin{% endblock %}

{% block content %}
  <div class="admin-header">
    <div>
      <h1>Library Administration</h1>
      <p style="color: #9ca3af;">Manage book catalogue entries.</p>
    </div>
  </div>

  <!-- Admin Navigation Tabs -->
  <div class="admin-tabs">
    <a href="/admin">Overview</a>
    <a href="/admin/books" class="active">Books</a>
    <a href="/admin/members">Members</a>
    <a href="/admin/loans">Loans & Returns</a>
    <a href="/admin/logs">Audit Logs</a>
  </div>

  {% if success %}
    <div class="alert alert-success">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-danger">{{ error }}</div>
  {% endif %}

  <div class="grid" style="grid-template-columns: 350px 1fr; align-items: start;">
    <!-- Add or Edit Book Form -->
    <div class="card" style="padding: 1.5rem;">
      <h3>{% if edit_book %}Edit Book{% else %}Add New Book{% endif %}</h3>
      
      <form action="{% if edit_book %}/admin/books/edit/{{ edit_book.id }}{% else %}/admin/books/add{% endif %}" method="POST">
        {{ form_token() }}
        
        <div class="form-group">
          <label for="title">Book Title</label>
          <input type="text" id="title" name="title" required value="{{ edit_book.title }}" placeholder="e.g. The Great Gatsby">
        </div>

        <div class="form-group">
          <label for="author">Author</label>
          <input type="text" id="author" name="author" required value="{{ edit_book.author }}" placeholder="e.g. F. Scott Fitzgerald">
        </div>

        <div class="form-group">
          <label for="published_year">Published Year</label>
          <input type="number" id="published_year" name="published_year" required value="{{ edit_book.published_year }}" placeholder="e.g. 1925">
        </div>

        <div class="form-group">
          <label for="isbn">ISBN</label>
          <input type="text" id="isbn" name="isbn" required value="{{ edit_book.isbn }}" placeholder="e.g. 9780743273565">
        </div>

        <div class="form-group">
          <label for="cover_image">Cover Image URL</label>
          <input type="text" id="cover_image" name="cover_image" value="{{ edit_book.cover_image }}" placeholder="e.g. /images/default-cover.png">
        </div>

        <div style="display: flex; gap: 0.5rem; margin-top: 1.5rem;">
          <button type="submit" class="btn btn-primary" style="flex-grow: 1;">
            {% if edit_book %}Save Changes{% else %}Add Book{% endif %}
          </button>
          {% if edit_book %}
            <a href="/admin/books" class="btn btn-secondary">Cancel</a>
          {% endif %}
        </div>
      </form>
    </div>

    <!-- Books List Table -->
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Cover</th>
            <th>Title</th>
            <th>Author</th>
            <th>Year</th>
            <th>ISBN</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for book in books %}
            <tr>
              <td>
                <img src="{{ book.cover_image|default('/images/default-cover.png') }}" alt="Cover" style="width: 40px; height: auto; border-radius: 4px;">
              </td>
              <td><strong>{{ book.title }}</strong></td>
              <td>{{ book.author }}</td>
              <td>{{ book.published_year }}</td>
              <td><code>{{ book.isbn }}</code></td>
              <td>
                {% if book.is_available == 1 %}
                  <span class="badge badge-available" style="position: static; font-size: 0.75rem; padding: 0.2rem 0.5rem;">Available</span>
                {% else %}
                  <span class="badge badge-borrowed" style="position: static; font-size: 0.75rem; padding: 0.2rem 0.5rem;">On Loan</span>
                {% endif %}
              </td>
              <td>
                <div style="display: flex; gap: 0.5rem;">
                  <a href="/admin/books?edit_id={{ book.id }}" class="btn btn-secondary btn-sm">Edit</a>
                  
                  <form action="/admin/books/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this book?');" style="display:inline;">
                    {{ form_token() }}
                    <input type="hidden" name="book_id" value="{{ book.id }}">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="7" style="text-align: center; color: #9ca3af; font-style: italic;">No books found in the collection. Add one to get started!</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
