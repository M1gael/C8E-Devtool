{% extends "base.twig" %}

{% block content %}
<div style="max-width: 450px; margin: 4rem auto;">
    {% if error %}
        <div class="alert alert-danger">
            {{ error }}
        </div>
    {% endif %}
    
    <div class="premium-card">
        <div class="card-header" style="text-align: center; padding-top: 2rem">
            <h2>{{ translate("admin_portal", lang) }}</h2>
            <p style="color:#64748b; font-size:0.95rem; margin-top:0.5rem">Sign in to manage catalog, members, and loans</p>
        </div>
        <div class="card-body">
            <form method="POST" action="/login">
                {{ form_token() }}
                
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" class="form-control" placeholder="e.g. admin" required>
                </div>
                
                <div class="form-group" style="margin-bottom: 2rem">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="e.g. ••••••••" required>
                </div>
                
                <button type="submit" class="btn btn-primary" style="width: 100%">{{ translate("login", lang) }}</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
