{% extends "base.twig" %}

{% block content %}
<div style="margin-top: 2rem; margin-bottom: 2rem;">
    <a href="/staff/dashboard" class="btn btn-secondary">&larr; {{ translate("staff_dashboard", lang) }}</a>
</div>

{% if success %}
    <div class="alert alert-success">{{ success }}</div>
{% endif %}
{% if error %}
    <div class="alert alert-danger">{{ error }}</div>
{% endif %}

<div style="display: grid; grid-template-columns: 1fr 350px; gap: 2rem; align-items: start; margin-top: 2rem">
    <!-- Members List -->
    <div class="premium-card">
        <div class="card-header">
            <h3>{{ translate("members", lang) }}</h3>
        </div>
        <div class="card-body" style="overflow-x:auto">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Join Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for member in members %}
                        <tr>
                            <td>{{ member.id }}</td>
                            <td><strong>{{ member.name }}</strong></td>
                            <td>{{ member.email }}</td>
                            <td>{{ member.join_date }}</td>
                            <td>
                                <div style="display:flex; gap: 0.5rem">
                                    <a href="/staff/members?edit={{ member.id }}" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem">Edit</a>
                                    <form method="POST" action="/staff/members/delete/{{ member.id }}" onsubmit="return confirm('Are you sure you want to delete this member?');">
                                        {{ form_token() }}
                                        <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.85rem">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" style="text-align:center; padding: 2rem; color: #64748b">No members registered.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Form: Add or Edit -->
    <div class="premium-card">
        <div class="card-header">
            <h3>
                {% if edit_member %}
                    {{ translate("edit_member", lang) }}
                {% else %}
                    {{ translate("add_member", lang) }}
                {% endif %}
            </h3>
        </div>
        <div class="card-body">
            <form method="POST" action="{% if edit_member %}/staff/members/edit/{{ edit_member.id }}{% else %}/staff/members/add{% endif %}">
                {{ form_token() }}
                
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" class="form-control" placeholder="e.g. Jane Doe" value="{{ edit_member.name }}" required>
                </div>
                
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="e.g. jane@example.com" value="{{ edit_member.email }}" required>
                </div>
                
                <div class="form-group">
                    <label for="join_date">Join Date</label>
                    <input type="date" id="join_date" name="join_date" class="form-control" placeholder="Select date" value="{{ edit_member.join_date | default(current_date) }}" required>
                </div>
                
                <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem">
                    <button type="submit" class="btn btn-primary" style="flex:1">
                        {% if edit_member %}Save{% else %}Add{% endif %}
                    </button>
                    {% if edit_member %}
                        <a href="/staff/members" class="btn btn-secondary">Cancel</a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
