{% extends "base.twig" %}

{% block content %}
<div style="margin-top: 2rem; margin-bottom: 2rem;">
    <a href="/staff/dashboard" class="btn btn-secondary">&larr; {{ translate("staff_dashboard", lang) }}</a>
</div>

{% if success %}
    <div class="alert alert-success">{{ success }}</div>
{% endif %}
{% if error %}
    <div class="alert alert-danger">{{ error }}</div>
{% endif %}

<div style="display: grid; grid-template-columns: 1fr 350px; gap: 2rem; align-items: start; margin-top: 2rem">
    <!-- Books List -->
    <div class="premium-card">
        <div class="card-header">
            <h3>{{ translate("manage_books", lang) }}</h3>
        </div>
        <div class="card-body" style="overflow-x:auto">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>{{ translate("title", lang) }}</th>
                        <th>{{ translate("author", lang) }}</th>
                        <th>{{ translate("year", lang) }}</th>
                        <th>{{ translate("isbn", lang) }}</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for book in books %}
                        <tr>
                            <td>
                                <img src="{{ book.cover_image | default('/images/default-cover.jpg') }}" alt="{{ book.title }}" style="width: 40px; height: 60px; object-fit: cover; border-radius: 4px">
                            </td>
                            <td><strong>{{ book.title }}</strong></td>
                            <td>{{ book.author }}</td>
                            <td>{{ book.published_year }}</td>
                            <td>{{ book.isbn }}</td>
                            <td>
                                <div style="display:flex; gap: 0.5rem">
                                    <a href="/staff/books?edit={{ book.id }}" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem">Edit</a>
                                    <form method="POST" action="/staff/books/delete/{{ book.id }}" onsubmit="return confirm('Are you sure you want to delete this book?');">
                                        {{ form_token() }}
                                        <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.85rem">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" style="text-align:center; padding: 2rem; color: #64748b">No books in catalog.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Form: Add or Edit -->
    <div class="premium-card">
        <div class="card-header">
            <h3>
                {% if edit_book %}
                    {{ translate("edit_book", lang) }}
                {% else %}
                    {{ translate("add_book", lang) }}
                {% endif %}
            </h3>
        </div>
        <div class="card-body">
            <form method="POST" action="{% if edit_book %}/staff/books/edit/{{ edit_book.id }}{% else %}/staff/books/add{% endif %}" enctype="multipart/form-data">
                {{ form_token() }}
                
                <div class="form-group">
                    <label for="title">{{ translate("title", lang) }}</label>
                    <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Clean Code" value="{{ edit_book.title }}" required>
                </div>
                
                <div class="form-group">
                    <label for="author">{{ translate("author", lang) }}</label>
                    <input type="text" id="author" name="author" class="form-control" placeholder="e.g. Robert C. Martin" value="{{ edit_book.author }}" required>
                </div>
                
                <div class="form-group">
                    <label for="published_year">{{ translate("year", lang) }}</label>
                    <input type="number" id="published_year" name="published_year" class="form-control" placeholder="e.g. 2008" value="{{ edit_book.published_year }}" required>
                </div>
                
                <div class="form-group">
                    <label for="isbn">{{ translate("isbn", lang) }}</label>
                    <input type="text" id="isbn" name="isbn" class="form-control" placeholder="e.g. 978-0132350884" value="{{ edit_book.isbn }}" required>
                </div>
                
                <div class="form-group">
                    <label for="cover_image_file">Cover Image</label>
                    <input type="file" id="cover_image_file" name="cover_image_file" class="form-control" placeholder="Select image file" accept="image/*">
                    {% if edit_book.cover_image %}
                        <div style="margin-top: 0.5rem">
                            <span style="font-size:0.85rem; color:#64748b">Current:</span>
                            <img src="{{ edit_book.cover_image }}" alt="Cover" style="width: 50px; display: block; margin-top: 0.25rem; border-radius:4px">
                        </div>
                    {% endif %}
                </div>
                
                <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem">
                    <button type="submit" class="btn btn-primary" style="flex:1">
                        {% if edit_book %}Save{% else %}Add{% endif %}
                    </button>
                    {% if edit_book %}
                        <a href="/staff/books" class="btn btn-secondary">Cancel</a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
