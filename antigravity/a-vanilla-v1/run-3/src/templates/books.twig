{% extends "base.twig" %}

{% block title %}Library Tracker — BookStack{% endblock %}

{% block content %}
<div class="dashboard-actions">
    <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="searchInput" class="search-input" placeholder="Search by title, author, or year..." oninput="filterBooks()">
    </div>
    <div class="books-count">
        Total Books: <span id="totalBooksCount" class="count-num">{{ books | length }}</span>
    </div>
</div>

<!-- Books Grid -->
<div id="booksGrid" class="books-grid">
    {% if books | length > 0 %}
        {% for book in books %}
            <div class="book-card" id="book-card-{{ book.id }}" data-title="{{ book.title | lower }}" data-author="{{ book.author | lower }}" data-year="{{ book.published_year }}">
                <div class="book-header">
                    <h4 class="book-title">{{ book.title }}</h4>
                </div>
                <div class="book-details">
                    <div class="book-author">
                        <i class="fa-solid fa-pen-nib"></i>
                        <span>By {{ book.author }}</span>
                    </div>
                    <div class="book-year">
                        <i class="fa-solid fa-calendar-days"></i>
                        <span>Published in {{ book.published_year }}</span>
                    </div>
                </div>
                <div class="book-actions">
                    <button class="btn btn-secondary btn-sm" onclick="openEditModal({{ book.id }}, '{{ book.title | replace("'", "\\'") }}', '{{ book.author | replace("'", "\\'") }}', {{ book.published_year }})">
                        <i class="fa-solid fa-edit"></i> Edit
                    </button>
                    <button class="btn btn-danger btn-sm" onclick="confirmDeleteBook({{ book.id }}, '{{ book.title | replace("'", "\\'") }}')">
                        <i class="fa-solid fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="empty-state" id="emptyState">
            <div class="empty-icon">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <h3>No books in your library</h3>
            <p>Get started by adding your first book to the collection.</p>
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="fa-solid fa-plus"></i> Add New Book
            </button>
        </div>
    {% endif %}
</div>

<!-- Add Book Modal -->
<div id="addModal" class="modal-overlay" onclick="closeModalOnOverlay(event, 'addModal')">
    <div class="modal-container">
        <div class="modal-header">
            <h3>Add New Book</h3>
            <button class="close-btn" onclick="closeModal('addModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form id="addBookForm" onsubmit="submitAddForm(event)">
            <div class="form-group">
                <label for="addTitle">Book Title</label>
                <input type="text" id="addTitle" class="form-control" placeholder="e.g. The Hobbit" required>
            </div>
            <div class="form-group">
                <label for="addAuthor">Author</label>
                <input type="text" id="addAuthor" class="form-control" placeholder="e.g. J.R.R. Tolkien" required>
            </div>
            <div class="form-group">
                <label for="addPublishedYear">Published Year</label>
                <input type="number" id="addPublishedYear" class="form-control" placeholder="e.g. 1937" min="1" max="2100" required>
            </div>
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Book</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Book Modal -->
<div id="editModal" class="modal-overlay" onclick="closeModalOnOverlay(event, 'editModal')">
    <div class="modal-container">
        <div class="modal-header">
            <h3>Edit Book</h3>
            <button class="close-btn" onclick="closeModal('editModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form id="editBookForm" onsubmit="submitEditForm(event)">
            <input type="hidden" id="editBookId">
            <div class="form-group">
                <label for="editTitle">Book Title</label>
                <input type="text" id="editTitle" class="form-control" placeholder="e.g. The Fellowship of the Ring" required>
            </div>
            <div class="form-group">
                <label for="editAuthor">Author</label>
                <input type="text" id="editAuthor" class="form-control" placeholder="e.g. J.R.R. Tolkien" required>
            </div>
            <div class="form-group">
                <label for="editPublishedYear">Published Year</label>
                <input type="number" id="editPublishedYear" class="form-control" placeholder="e.g. 1954" min="1" max="2100" required>
            </div>
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Book</button>
            </div>
        </form>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="toast-notification">
    <i class="fa-solid" id="toastIcon"></i>
    <span id="toastMessage"></span>
</div>

{% endblock %}

{% block javascripts %}
<script>
    // Client-side real-time filtering
    function filterBooks() {
        const query = document.getElementById('searchInput').value.toLowerCase().trim();
        const cards = document.querySelectorAll('.book-card');
        let visibleCount = 0;
        
        cards.forEach(card => {
            const title = card.getAttribute('data-title');
            const author = card.getAttribute('data-author');
            const year = card.getAttribute('data-year');
            
            if (title.includes(query) || author.includes(query) || year.includes(query)) {
                card.style.display = '';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });
        
        const emptyState = document.getElementById('emptyState');
        if (visibleCount === 0 && cards.length > 0) {
            // Show a temporary empty search state if we filtered everything out
            let tempEmpty = document.getElementById('searchEmptyState');
            if (!tempEmpty) {
                tempEmpty = document.createElement('div');
                tempEmpty.id = 'searchEmptyState';
                tempEmpty.className = 'empty-state';
                tempEmpty.style.gridColumn = '1 / -1';
                tempEmpty.innerHTML = `
                    <div class="empty-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
                    <h3>No matching books found</h3>
                    <p>Try refining your search terms.</p>
                `;
                document.getElementById('booksGrid').appendChild(tempEmpty);
            }
        } else {
            const tempEmpty = document.getElementById('searchEmptyState');
            if (tempEmpty) {
                tempEmpty.remove();
            }
        }
        
        document.getElementById('totalBooksCount').innerText = visibleCount;
    }

    // Modal Control Helper
    function openModal(id) {
        document.getElementById(id).classList.add('active');
    }
    
    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }
    
    function closeModalOnOverlay(event, id) {
        if (event.target === document.getElementById(id)) {
            closeModal(id);
        }
    }
    
    // Add Modal
    function openAddModal() {
        document.getElementById('addBookForm').reset();
        openModal('addModal');
    }
    
    async function submitAddForm(event) {
        event.preventDefault();
        const title = document.getElementById('addTitle').value;
        const author = document.getElementById('addAuthor').value;
        const published_year = parseInt(document.getElementById('addPublishedYear').value);
        
        try {
            const response = await fetch('/api/books', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ title, author, published_year })
            });
            
            const result = await response.json();
            if (response.ok) {
                showToast('Book added successfully!', 'success');
                closeModal('addModal');
                setTimeout(() => window.location.reload(), 800);
            } else {
                showToast(result.error || 'Failed to add book', 'error');
            }
        } catch (err) {
            showToast('Network error occurred.', 'error');
            console.error(err);
        }
    }
    
    // Edit Modal
    function openEditModal(id, title, author, published_year) {
        document.getElementById('editBookId').value = id;
        document.getElementById('editTitle').value = title;
        document.getElementById('editAuthor').value = author;
        document.getElementById('editPublishedYear').value = published_year;
        openModal('editModal');
    }
    
    async function submitEditForm(event) {
        event.preventDefault();
        const id = document.getElementById('editBookId').value;
        const title = document.getElementById('editTitle').value;
        const author = document.getElementById('editAuthor').value;
        const published_year = parseInt(document.getElementById('editPublishedYear').value);
        
        try {
            const response = await fetch(`/api/books/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ title, author, published_year })
            });
            
            const result = await response.json();
            if (response.ok) {
                showToast('Book updated successfully!', 'success');
                closeModal('editModal');
                setTimeout(() => window.location.reload(), 800);
            } else {
                showToast(result.error || 'Failed to update book', 'error');
            }
        } catch (err) {
            showToast('Network error occurred.', 'error');
            console.error(err);
        }
    }
    
    // Delete
    async function confirmDeleteBook(id, title) {
        if (confirm(`Are you sure you want to delete "${title}"?`)) {
            try {
                const response = await fetch(`/api/books/${id}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                if (response.ok) {
                    showToast('Book deleted successfully!', 'success');
                    const card = document.getElementById(`book-card-${id}`);
                    if (card) {
                        card.style.transform = 'scale(0.8) translateY(20px)';
                        card.style.opacity = '0';
                        setTimeout(() => {
                            card.remove();
                            // Update count
                            const remaining = document.querySelectorAll('.book-card').length;
                            document.getElementById('totalBooksCount').innerText = remaining;
                            if (remaining === 0) {
                                window.location.reload(); // Reload to show empty state
                            }
                        }, 300);
                    }
                } else {
                    showToast(result.error || 'Failed to delete book', 'error');
                }
            } catch (err) {
                showToast('Network error occurred.', 'error');
                console.error(err);
            }
        }
    }
    
    // Toast notifications
    function showToast(message, type) {
        const toast = document.getElementById('toast');
        const toastIcon = document.getElementById('toastIcon');
        const toastMsg = document.getElementById('toastMessage');
        
        toastMsg.innerText = message;
        toast.className = 'toast-notification active ' + type;
        
        if (type === 'success') {
            toastIcon.className = 'fa-solid fa-circle-check';
        } else {
            toastIcon.className = 'fa-solid fa-circle-xmark';
        }
        
        setTimeout(() => {
            toast.classList.remove('active');
        }, 3000);
    }
</script>
{% endblock %}
